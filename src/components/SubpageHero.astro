---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  bannerImage: ImageMetadata;
  bannerAlt: string;
  breadcrumb: string;
  eyebrow: string;
  title: string;
  description: string;
}

const { bannerImage, bannerAlt, breadcrumb, eyebrow, title, description } = Astro.props;
---

<header class="subhero">
  <div class="banner">
    <Image src={bannerImage} alt={bannerAlt} width={1920} loading="eager" />
  </div>

  <div class="subhead">
    <div class="subhead-in">
      <nav class="breadcrumb" aria-label="Breadcrumb">Home / {breadcrumb}</nav>
      <span class="eyebrow">{eyebrow}</span>
      <h1>{title}</h1>
      <p>{description}</p>
    </div>
  </div>
</header>

<style>
  .subhero {
    background: #fff;
  }

  .banner {
    width: 100%;
    height: clamp(360px, 52vh, 560px);
    overflow: hidden;
    background: var(--color-canvas, #f5f0eb);
  }

  .banner img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .subhead {
    background: #fff;
    border-bottom: 1px solid var(--color-line);
  }

  .subhead-in {
    max-width: 1280px;
    margin: 0 auto;
    padding: clamp(40px, 5vw, 76px) 48px;
  }

  .breadcrumb {
    font-family: var(--font-mono, monospace);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #6a6253;
    margin-bottom: 16px;
  }

  .eyebrow {
    display: block;
    font-family: var(--font-mono, monospace);
    text-transform: uppercase;
    color: var(--color-orange, #e0712f);
    letter-spacing: 0.08em;
    font-size: 13px;
    margin-bottom: 10px;
  }

  h1 {
    font-family: 'Archivo', sans-serif;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.02;
    font-size: clamp(36px, 5vw, 68px);
    max-width: 18ch;
    margin: 0;
  }

  p {
    margin-top: 18px;
    font-size: clamp(16px, 1.5vw, 19px);
    color: #4a4338;
    max-width: 60ch;
    line-height: 1.55;
  }

  @media (max-width: 860px) {
    .banner {
      height: clamp(200px, 32vh, 300px);
    }

    .subhead-in {
      padding: 36px 28px;
    }
  }
</style>

---
const steps = [
  {
    num: '01', title: 'Free Estimate', lead: 'A real number, no surprises',
    body: 'We walk the space, talk through tile and layout, and give you a written estimate\u2014materials and labor, line by line.',
    tag: '24\u201348 hr turnaround',
  },
  {
    num: '02', title: 'We Set the Tile', lead: 'Square, level, clean',
    body: 'Waterproofing done right, layout snapped to the room, grout lines you could lay a straightedge across. We protect your home and clean up every day.',
    tag: 'Set dead level',
  },
  {
    num: '03', title: 'Enjoy It for Years', lead: 'Built to last',
    body: "You're left with a kitchen or bath that's sealed, solid, and made to hold up to daily life\u2014backed by a setter who stands behind the work.",
    tag: 'Since 2019',
  },
];
---

<section class="process" id="how">
  <div class="process-in">
    <div class="process-head">
      <div class="eyebrow" style="color:var(--color-orange);margin-bottom:18px;">How It Works</div>
      <h2>Three Steps, One Setter</h2>
    </div>
    <div class="proc-grid">
      {steps.map((s) => (
        <div class="proc-step reveal">
          <span class="dot"></span>
          <div class="n">{s.num}</div>
          <h3>{s.title}</h3>
          <div class="lead">{s.lead}</div>
          <p>{s.body}</p>
          <span class="tag">{s.tag}</span>
        </div>
      ))}
    </div>
    <div class="process-foot">
      <a href="/contact" class="btn-orange">Get a free estimate</a>
    </div>
  </div>
</section>

<style>
  .process { background: var(--color-canvas); color: var(--color-ink); padding: clamp(72px, 9vw, 120px) 0; }
  .process-in { max-width: 1280px; margin: 0 auto; padding: 0 48px; }
  .process-head { max-width: 48ch; margin-bottom: clamp(40px, 5vw, 72px); }
  .process-head h2 {
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1;
    font-size: clamp(34px, 5vw, 68px);
    white-space: nowrap;
  }
  .proc-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-top: 1px solid var(--color-line-strong);
  }
  .proc-step { padding: 40px 36px 8px 0; position: relative; }
  .proc-step:not(:last-child) { border-right: 1px solid var(--color-line); padding-right: 48px; }
  .proc-step:not(:first-child) { padding-left: 48px; }
  .dot {
    position: absolute;
    top: -7px;
    left: 0;
    width: 13px;
    height: 13px;
    border-radius: 50%;
    background: var(--color-orange);
  }
  .proc-step:not(:first-child) .dot { left: 48px; }
  .n {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(48px, 5vw, 76px);
    line-height: 0.9;
    color: transparent;
    -webkit-text-stroke: 1.5px var(--color-darkbeige);
    margin-bottom: 22px;
  }
  h3 {
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: -0.01em;
    font-size: clamp(22px, 2.2vw, 30px);
    margin-bottom: 10px;
    color: var(--color-ink);
  }
  .lead {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-orange);
    margin-bottom: 16px;
  }
  p { font-size: 16px; line-height: 1.6; color: var(--color-body); max-width: 38ch; }
  .tag {
    display: inline-block;
    margin-top: 18px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
    border: 1px solid var(--color-line-strong);
    border-radius: 999px;
    padding: 6px 14px;
  }
  .process-foot {
    margin-top: clamp(40px, 5vw, 64px);
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }
  @media (max-width: 860px) {
    .process-head h2 { white-space: normal; font-size: clamp(30px, 8vw, 44px); }
    .proc-grid { grid-template-columns: 1fr; border-top: none; }
    .proc-step { padding: 36px 0 36px 28px !important; border-right: none !important; border-left: 1px solid var(--color-line-strong); }
    .proc-step .dot, .proc-step:not(:first-child) .dot { left: -7px; top: 36px; }
    .n { margin-bottom: 14px; }
    .process-in { padding: 0 20px; }
  }
  @media (max-width: 480px) {
    .process-in { padding: 0 16px; }
  }
</style>

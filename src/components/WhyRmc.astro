---
import { Image } from 'astro:assets';
import coolLargeformat from '../assets/photos/cool-largeformat.jpg';

const stats = [
  { v: '20+', b: 'Years on the trowel', s: 'Hands-on, every job' },
  { v: '2nd', b: 'Generation tile setter', s: "It's the family trade" },
  { v: '1', b: 'Person, quote to cleanup', s: 'No subs, no handoffs' },
  { v: "'19", b: 'Serving Northern Colorado', s: 'Loveland & the Front Range since 2019' },
];
---

<section class="why" id="about">
  <div class="bg">
    <Image src={coolLargeformat} alt="Large-format tile shower" width={1920} loading="lazy" class="grade" />
  </div>
  <div class="why-in">
    <div class="why-lead" data-reveal="left">
      <div class="eyebrow" style="color:var(--color-orange);margin-bottom:24px;">Why RMC</div>
      <h2>Most Tile Problems Start Before the First Tile Goes Down</h2>
      <p>So we sweat the part you can't see&mdash;the layout, the waterproofing, the prep. One setter owns the whole job, start to finish, and stands behind it.</p>
    </div>
    <div class="why-stats" data-reveal="right" style="--delay:120ms">
      {stats.map((st) => (
        <div class="why-stat">
          <span class="v">{st.v}</span>
          <span class="t">
            <b>{st.b}</b>
            <span>{st.s}</span>
          </span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .why {
    position: relative;
    background: var(--color-ink);
    color: var(--color-beige);
    overflow: hidden;
    isolation: isolate;
    padding: clamp(80px, 10vw, 140px) 0;
  }
  .bg { position: absolute; inset: 0; z-index: -2; }
  .bg :global(img) { width: 100%; height: 100%; object-fit: cover; }
  .why::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(100deg, rgba(17,17,17,0.94) 0%, rgba(17,17,17,0.86) 46%, rgba(17,17,17,0.66) 100%);
  }
  .why-in {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 48px;
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(48px, 6vw, 96px);
    align-items: center;
  }
  h2 {
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.04;
    font-size: clamp(30px, 4vw, 58px);
    max-width: 16ch;
  }
  .why-lead p {
    margin-top: 24px;
    font-size: 18px;
    line-height: 1.6;
    color: rgba(255,247,233,0.82);
    max-width: 46ch;
  }
  .why-stats { display: flex; flex-direction: column; }
  .why-stat {
    display: flex;
    align-items: baseline;
    gap: 22px;
    padding: 26px 0;
    border-top: 1px solid rgba(255,247,233,0.18);
  }
  .why-stat:last-child { border-bottom: 1px solid rgba(255,247,233,0.18); }
  .v {
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 0.9;
    font-size: clamp(40px, 4.4vw, 64px);
    color: var(--color-orange);
    flex: none;
    min-width: 3.2ch;
  }
  .t { font-size: 17px; line-height: 1.45; color: var(--color-beige); }
  .t b { font-weight: 600; }
  .t span {
    display: block;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(255,247,233,0.6);
    margin-top: 5px;
  }
  @media (max-width: 860px) {
    .why-in { grid-template-columns: 1fr; gap: 40px; padding: 0 20px; }
    .v { font-size: 46px; }
  }
  @media (max-width: 480px) {
    .why-in { padding: 0 16px; }
  }
</style>

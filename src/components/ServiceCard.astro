---
import { Image } from 'astro:assets';

interface Props {
  num: string;
  title: string;
  description: string;
  image: ImageMetadata;
  alt: string;
  tall?: boolean;
}

const { num, title, description, image, alt, tall = false } = Astro.props;
---

<article class:list={['svc', { tall }]}>
  <div class="bg">
    <Image src={image} alt={alt} width={640} loading="lazy" class="grade" />
  </div>
  <div class="svc-in">
    <div class="num">{num}</div>
    <h3>{title}</h3>
    <p>{description}</p>
  </div>
</article>

<style>
  .svc {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--color-line);
    background: #fff;
    min-height: 300px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    color: var(--color-beige);
    isolation: isolate;
    transition: transform 0.25s ease;
  }
  .svc:hover { transform: translateY(-4px); }
  .bg { position: absolute; inset: 0; z-index: -2; }
  .bg :global(img) { width: 100%; height: 100%; object-fit: cover; }
  .svc::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(180deg, rgba(17,17,17,0.12) 0%, rgba(17,17,17,0.35) 48%, rgba(17,17,17,0.82) 100%);
  }
  .svc-in { padding: 26px; }
  .num {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    opacity: 0.8;
  }
  h3 {
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: -0.02em;
    font-size: 26px;
    margin: 10px 0 8px;
  }
  p {
    font-size: 14.5px;
    line-height: 1.5;
    color: rgba(255,247,233,0.86);
    max-width: 34ch;
  }
  .tall { grid-row: span 2; min-height: 0; }
  @media (max-width: 860px) { .tall { grid-row: auto; } }
</style>

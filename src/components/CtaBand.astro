---
import logo from '../assets/brand/logo-final.svg';

interface Props {
  headline?: string;
  description?: string;
}

const {
  headline = "Let's Tile<br>Your Place.",
  description = "Planning a kitchen or bath remodel\u2014or building new? Tell us about the space and we'll get you a real number.",
} = Astro.props;
---

<section class="cta-sec">
  <div class="cta-in">
    <h2 class="serif" set:html={headline} />
    <div class="cta-side">
      <img class="logo" src={logo.src} alt="RMC Tile">
      <div class="ey">Free estimates</div>
      <p>{description}</p>
      <a href="/contact" class="btn-dark">Get a free estimate</a>
    </div>
  </div>
</section>

<style>
  .cta-sec { background: var(--color-orange); color: #fff; padding: 120px 48px; }
  .cta-in {
    max-width: 1280px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 60px;
    align-items: center;
  }
  h2 {
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 0.96;
    font-size: clamp(48px, 8vw, 120px);
  }
  .cta-side { display: flex; flex-direction: column; gap: 22px; }
  .logo {
    height: 30px;
    width: auto;
    filter: invert(1) brightness(1.7);
    align-self: flex-start;
  }
  .ey {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.8);
  }
  p { font-size: 19px; font-weight: 500; line-height: 1.45; }
  .cta-side :global(.btn-dark) { align-self: flex-start; }
  @media (max-width: 860px) {
    .cta-sec { padding: 72px 28px; }
    .cta-in { grid-template-columns: 1fr; gap: 36px; }
  }
</style>

---
interface Value {
  label: string;
  title: string;
  description: string;
}

interface Props {
  eyebrow: string;
  heading: string;
  values: Value[];
}

const { eyebrow, heading, values } = Astro.props;
---

<section class="section-pad" style="background:var(--color-canvas);">
  <div class="container">
    <div class="sec-eyebrow" data-reveal="up">{eyebrow}</div>
    <h2 class="sec-h2" data-reveal="up" style="--delay:100ms">{heading}</h2>
    <div class="values">
      {values.map((v, i) => (
        <div class="value" data-reveal="scale" style={`--delay:${i * 100}ms`}>
          <div class="vn">{v.label}</div>
          <h3>{v.title}</h3>
          <p>{v.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .sec-eyebrow {
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-orange);
    margin-bottom: 18px;
  }
  .sec-h2 {
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.04;
    font-size: clamp(28px, 3.6vw, 48px);
    color: var(--color-ink);
    max-width: 22ch;
  }
  .values {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 48px;
  }
  .value {
    background: #fff;
    border: 1px solid var(--color-canvas-line);
    border-radius: 16px;
    padding: 32px 28px;
  }
  .vn {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-orange);
    margin-bottom: 16px;
  }
  h3 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 21px;
    letter-spacing: -0.01em;
    color: var(--color-ink);
    margin-bottom: 10px;
  }
  p { font-size: 15px; line-height: 1.6; color: var(--color-body); }
  @media (max-width: 860px) { .values { grid-template-columns: 1fr; } }
</style>

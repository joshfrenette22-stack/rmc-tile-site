  'rmc-tile-223.jpg': 'kitchens',
  'rmc-tile-224.jpg': 'showers',
  'rmc-tile-243.jpg': 'custom',
};

// Files to exclude from the gallery entirely
const excludeFiles = new Set(['tile-stack.png', 'rmc-tile-244.jpg', 'rmc-tile-245.jpg']);

// Featured photos — curated best-of mix
const featuredFiles = new Set([
  'cool-chevron.jpg', 'cool-floor.jpg', 'cool-herringbone.jpg', 'cool-plank.jpg',
  'cool-striated-shower.jpg', 'warm-tub.jpg', 'cool-kitchen.jpg', 'warm-fireplace.jpg',
  'warm-stone.jpg', 'cool-basketweave-shower.jpg', 'cool-bench-shower.jpg',
  'cool-largeformat.jpg', 'warm-subway.jpg', 'cool-blackaccent-shower.jpg',
  'warm-green-powder.jpg', 'warm-green-laundry.jpg', 'warm-powder.jpg', 'warm-green-bath.jpg',
  'rmc-tile-009.jpg', 'rmc-tile-010.jpg', 'rmc-tile-014.jpg', 'rmc-tile-018.jpg',
  'rmc-tile-021.jpg', 'rmc-tile-023.jpg', 'rmc-tile-024.jpg', 'rmc-tile-030.jpg',
  'rmc-tile-038.jpg', 'rmc-tile-090.jpg', 'rmc-tile-094.jpg', 'rmc-tile-100.jpg',
  'rmc-tile-127.jpg', 'rmc-tile-130.jpg', 'rmc-tile-195.jpg', 'rmc-tile-205.jpg',
  'IMG_9111.jpeg',
]);

// Build gallery data from glob
const galleryPhotos = Object.entries(allPhotos)
  .filter(([path]) => {
    const fileName = path.split('/').pop() || '';
    return !excludeFiles.has(fileName);
  })
  .map(([path, mod]) => {
    const fileName = path.split('/').pop() || '';
    const cat = categoryMap[fileName] || 'custom';
    const featured = featuredFiles.has(fileName);
    return { src: mod.default, cat, featured, fileName };
  });

// Sort: featured first, then by filename
const featuredPhotos = galleryPhotos.filter((p) => p.featured);
const nonFeatured = galleryPhotos.filter((p) => !p.featured);
const allGalleryPhotos = [...featuredPhotos, ...nonFeatured];

const filters = ['featured', 'showers', 'kitchens', 'baths', 'floors', 'custom'];
const filterLabels: Record<string, string> = {
  featured: 'Featured', showers: 'Showers', kitchens: 'Kitchens',
  baths: 'Baths', floors: 'Floors', custom: 'Custom',
};
---

<section class="section-pad" style="background:var(--color-canvas);">
  <div class="container">
    <div class="filters" id="filters" data-reveal="up">
      {filters.map((f) => (
        <button class:list={[{ active: f === 'featured' }]} data-filter={f}>{filterLabels[f]}</button>
      ))}
    </div>

    <div class="gallery" id="gallery" data-reveal="up" style="--delay:150ms">
      {allGalleryPhotos.map((p) => (
        <figure data-cat={p.cat} data-featured={p.featured ? 'true' : 'false'} class={p.featured ? '' : 'hide'}>
          <img
            src={p.src.src}
            width={p.src.width}
            height={p.src.height}
            alt={`RMC Tile ${p.cat} project`}
            loading="lazy"
            decoding="async"
          />
          <figcaption>{p.cat.charAt(0).toUpperCase() + p.cat.slice(1)}</figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<!-- Lightbox -->
<div class="lightbox" id="lightbox" aria-hidden="true">
  <button class="close" id="lbClose" aria-label="Close">&times;</button>
  <button class="nav-arrow prev" id="lbPrev" aria-label="Previous">&#8249;</button>
  <img id="lbImg" src="" alt="">
  <button class="nav-arrow next" id="lbNext" aria-label="Next">&#8250;</button>
</div>

<script>
  const btns = document.querySelectorAll('#filters button');
  const figs = Array.from(document.querySelectorAll('#gallery figure'));

  btns.forEach((b) => {
    b.addEventListener('click', () => {
      btns.forEach((x) => x.classList.remove('active'));
      b.classList.add('active');
      const f = (b as HTMLElement).dataset.filter;
      figs.forEach((fig) => {
        const el = fig as HTMLElement;
        if (f === 'featured') {
          fig.classList.toggle('hide', el.dataset.featured !== 'true');
        } else {
          fig.classList.toggle('hide', el.dataset.cat !== f);
        }
      });
    });
  });

  // Lightbox
  const lb = document.getElementById('lightbox')!;
  const lbImg = document.getElementById('lbImg') as HTMLImageElement;
  let idx = 0;

  function visible() { return figs.filter((f) => !f.classList.contains('hide')); }

  function openLb(fig: Element) {
    const v = visible();
    idx = v.indexOf(fig);
    showLb();
    lb.classList.add('open');
    lb.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function showLb() {
    const v = visible();
    const el = v[idx].querySelector('img')!;
    lbImg.src = (el as HTMLImageElement).src;
    lbImg.alt = (el as HTMLImageElement).alt;
  }

  function closeLb() {
    lb.classList.remove('open');
    lb.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  function stepLb(d: number) {
    const v = visible();
    idx = (idx + d + v.length) % v.length;
    showLb();
  }

  figs.forEach((fig) => fig.addEventListener('click', () => openLb(fig)));
  document.getElementById('lbClose')!.addEventListener('click', closeLb);
  document.getElementById('lbPrev')!.addEventListener('click', (e) => { e.stopPropagation(); stepLb(-1); });
  document.getElementById('lbNext')!.addEventListener('click', (e) => { e.stopPropagation(); stepLb(1); });
  lb.addEventListener('click', (e) => { if (e.target === lb) closeLb(); });
  document.addEventListener('keydown', (e) => {
    if (!lb.classList.contains('open')) return;
    if (e.key === 'Escape') closeLb();
    if (e.key === 'ArrowLeft') stepLb(-1);
    if (e.key === 'ArrowRight') stepLb(1);
  });

  // Touch swipe support for lightbox
  let touchStartX = 0;
  lb.addEventListener('touchstart', (e) => {
    touchStartX = e.changedTouches[0].clientX;
  }, { passive: true });
  lb.addEventListener('touchend', (e) => {
    const dx = e.changedTouches[0].clientX - touchStartX;
    if (Math.abs(dx) > 40) stepLb(dx < 0 ? 1 : -1);
  }, { passive: true });
</script>

<style>
  /* Filters */
  .filters { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 36px; }
  .filters :global(button) {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ink);
    background: #fff;
    border: 1px solid var(--color-canvas-line);
    border-radius: 999px;
    padding: 10px 18px;
    min-height: 44px;
    cursor: pointer;
    transition: all 0.18s;
  }
  .filters :global(button:hover) { border-color: var(--color-orange); }
  .filters :global(button.active) {
    background: var(--color-ink);
    color: var(--color-beige);
    border-color: var(--color-ink);
  }

  /* Gallery masonry */
  .gallery { columns: 3; column-gap: 16px; }
  .gallery :global(figure) {
    break-inside: avoid;
    margin: 0 0 16px;
    position: relative;
    border-radius: 14px;
    overflow: hidden;
    cursor: zoom-in;
    isolation: isolate;
  }
  .gallery :global(figure img) {
    width: 100%;
    display: block;
    transition: transform 0.5s ease;
  }
  .gallery :global(figure:hover img) { transform: scale(1.05); }
  .gallery :global(figcaption) {
    position: absolute;
    left: 14px; bottom: 12px; right: 14px;
    z-index: 2;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-beige);
    opacity: 0;
    transform: translateY(6px);
    transition: 0.3s;
  }
  .gallery :global(figure::after) {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(180deg, transparent 55%, rgba(17,17,17,0.6));
    opacity: 0;
    transition: 0.3s;
  }
  .gallery :global(figure:hover figcaption),
  .gallery :global(figure:hover::after) {
    opacity: 1;
    transform: none;
  }
  .gallery :global(figure.hide) { display: none; }
  @media (max-width: 980px) { .gallery { columns: 2; } }
  @media (max-width: 560px) { .gallery { columns: 1; } }

  /* Lightbox */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(17,17,17,0.92);
    display: none;
    align-items: center;
    justify-content: center;
    padding: 5vw;
  }
  .lightbox:global(.open) { display: flex; }
  .lightbox :global(#lbImg) {
    max-width: 90vw;
    max-height: 86vh;
    border-radius: 10px;
    box-shadow: 0 30px 80px rgba(0,0,0,0.5);
  }
  .close {
    position: absolute;
    top: 22px; right: 26px;
    width: 46px; height: 46px;
    border-radius: 50%;
    border: 1px solid rgba(255,247,233,0.4);
    background: transparent;
    color: var(--color-beige);
    font-size: 24px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .close:hover { background: rgba(255,247,233,0.12); }
  .nav-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 54px; height: 54px;
    border-radius: 50%;
    border: 1px solid rgba(255,247,233,0.4);
    background: transparent;
    color: var(--color-beige);
    font-size: 24px;
    cursor: pointer;
  }
  .nav-arrow:hover { background: rgba(255,247,233,0.12); }
  .prev { left: 3vw; }
  .next { right: 3vw; }
  @media (max-width: 560px) {
    .nav-arrow { width: 40px; height: 40px; font-size: 20px; }
    .prev { left: 8px; }
    .next { right: 8px; }
  }
</style>
